#!/usr/bin/env bash
# AO-005 hardened Amp Orb resume hook for build000r/swimmers.
# Must fit Amp's 10s non-blocking wake budget; slow repair is backgrounded.
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

AGENT_STATE_DIR="${AGENT_STATE_DIR:-$ROOT/.agents/state}"
AGENT_LOG_DIR="${AGENT_LOG_DIR:-$ROOT/.agents/logs}"
STATUS_FILE="$AGENT_STATE_DIR/resume-status.json"
LOG_FILE="$AGENT_LOG_DIR/resume.log"
MIN_FREE_GB="${SWIMMERS_ORB_RESUME_MIN_FREE_GB:-10}"
PINNED_RUST="${SWIMMERS_ORB_RUST_VERSION:-1.88.0}"
export CARGO_HOME="${CARGO_HOME:-$HOME/.cargo}"
export RUSTUP_HOME="${RUSTUP_HOME:-$HOME/.rustup}"
export PATH="$CARGO_HOME/bin:$PATH"
START_EPOCH="$(date +%s)"
FAILURE_CLASS="setup"
FAILURE_REASON="unexpected resume failure"
REPAIR_STARTED=false

mkdir -p "$AGENT_STATE_DIR" "$AGENT_LOG_DIR"
touch "$LOG_FILE"
exec > >(tee -a "$LOG_FILE") 2> >(tee -a "$LOG_FILE" >&2)

log() { printf 'swimmers-orb-resume: %s\n' "$*"; }

json_quote() {
  python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1" 2>/dev/null \
    || printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')"
}

disk_json() {
  df -Pk / | awk 'NR==2 {printf "{\"filesystem\":\"%s\",\"size_kb\":%s,\"used_kb\":%s,\"available_kb\":%s,\"capacity\":\"%s\",\"mount\":\"%s\"}", $1, $2, $3, $4, $5, $6}'
}

disk_available_gb() {
  df -Pk / | awk 'NR==2 {printf "%d", $4 / 1024 / 1024}'
}

emit_status() {
  local exit_code="$1"
  local end_epoch duration status
  end_epoch="$(date +%s)"
  duration="$((end_epoch - START_EPOCH))"
  status="ok"
  if [[ "$exit_code" -ne 0 ]]; then
    status="error"
  fi
  local payload
  payload="$(printf '{"schema_version":1,"repo":"build000r/swimmers","script":"resume","status":%s,"failure_class":%s,"reason":%s,"exit_code":%s,"duration_seconds":%s,"disk":%s,"rust_toolchain":%s,"repair_started":%s,"log_file":%s,"timestamp":%s}\n' \
    "$(json_quote "$status")" \
    "$(json_quote "$FAILURE_CLASS")" \
    "$(json_quote "$FAILURE_REASON")" \
    "$exit_code" \
    "$duration" \
    "$(disk_json)" \
    "$(json_quote "$PINNED_RUST")" \
    "$REPAIR_STARTED" \
    "$(json_quote "$LOG_FILE")" \
    "$(json_quote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")")"
  printf '%s' "$payload" > "$STATUS_FILE"
  printf 'AGENT_RESUME_RESULT_JSON %s' "$payload" >&2
}

on_exit() {
  local exit_code="$1"
  if [[ "$exit_code" -eq 0 ]]; then
    FAILURE_CLASS="none"
    FAILURE_REASON="resume ok"
  fi
  emit_status "$exit_code"
}
trap 'on_exit $?' EXIT

fail() {
  FAILURE_CLASS="$1"
  FAILURE_REASON="$2"
  local code="$3"
  log "FAIL[$FAILURE_CLASS]: $FAILURE_REASON"
  exit "$code"
}

log "start: $(date -u +%Y-%m-%dT%H:%M:%SZ)"

FREE_GB="$(disk_available_gb)"
if [[ "$FREE_GB" -lt "$MIN_FREE_GB" ]]; then
  fail capacity "need at least ${MIN_FREE_GB}GB free on fixed Orb disk during Rust resume; found ${FREE_GB}GB" 30
fi

command -v curl >/dev/null 2>&1 || fail dependency "missing required command: curl" 20
command -v git >/dev/null 2>&1 || fail dependency "missing required command: git" 20
command -v python3 >/dev/null 2>&1 || fail dependency "missing required command: python3" 20

if [[ -f "$CARGO_HOME/env" ]]; then
  # shellcheck source=/dev/null
  source "$CARGO_HOME/env"
fi

if command -v rustup >/dev/null 2>&1 && rustup run "$PINNED_RUST" rustc --version >/dev/null 2>&1; then
  log "toolchain present: $(rustup run "$PINNED_RUST" rustc --version)"
else
  REPAIR_STARTED=true
  log "toolchain ${PINNED_RUST} missing; starting non-blocking rustup repair"
  (
    if ! command -v rustup >/dev/null 2>&1; then
      curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain "$PINNED_RUST" --profile minimal
    else
      rustup toolchain install "$PINNED_RUST" --profile minimal
    fi
  ) >>"$AGENT_LOG_DIR/resume-repair.log" 2>&1 &
fi

log "resume fast checks ok"
