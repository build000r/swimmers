{
  "name": "throngterm",
  "version": "1.0.0",
  "description": "Thronglet-powered mobile terminal manager",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "lsof -ti:${PORT:-3210} | xargs kill -9 2>/dev/null; sleep 0.3; node server/index.js",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null; true"
  },
  "dependencies": {
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  }
}
