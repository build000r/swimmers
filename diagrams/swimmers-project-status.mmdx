## chart erd Swimmers File-Store Data Model
```mermaid
erDiagram
  PERSISTED_SESSION ||--o| THOUGHT_SNAPSHOT : "keyed by session_id"
  PERSISTED_SESSION }o--o| REPO_THEME : "repo colors override"
  DIR_GROUP_MEMBERSHIPS ||--o{ DIR_GROUP_DELTA : contains
  THOUGHT_CONFIG ||--o| PERSISTED_SESSION : "daemon runtime applies"
  PERSISTED_SESSION {
    string session_id PK
    string tmux_name
    string state
    string tool
    u64 token_count
    u64 context_limit
    string thought_state
    string rest_state
    bool commit_candidate
  }
  THOUGHT_SNAPSHOT {
    string session_id PK
    string thought
    string thought_state
    string thought_source
    string rest_state
    u64 token_count
    u64 context_limit
    datetime updated_at
  }
  THOUGHT_CONFIG {
    string file "thought_config.json"
    string daemon_defaults
  }
  DIR_GROUP_MEMBERSHIPS {
    string file "dir_groups.json"
    string directory PK
    string group
  }
  DIR_GROUP_DELTA {
    string directory
    string op "add remove move"
  }
  REPO_THEME {
    string file "colors.json"
    string repo PK
    string colors
    string sprite_override
  }
```
