!/assets/dragon/mouth-closed/
!/assets/dragon/mouth-open/
!/assets/dragon/fire-left-full/
!/assets/dragon/fire-left-mid/
!/assets/dragon/fire-left-short/
!/assets/dragon/fire-right-full/
!/assets/dragon/fire-right-mid/
!/assets/dragon/fire-right-short/
