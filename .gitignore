!/assets/dragon/*/right.png
!/assets/dragon/*/front.png
!/assets/dragon/*/back.png
!/assets/dragon/*/3q-left.png
!/assets/dragon/*/3q-right.png
!/assets/dragon/*/back-left.png
!/assets/dragon/*/back-right.png
